from dto.index import *
from functions.services.artistcore.font.fontLibs import *
from PIL import Image, ImageDraw, ImageFilter

try:
    from rembg import remove as RembgRemove
except Exception:
    RembgRemove = None

def Font(size, bold=False, zen=False, arial=False):
    name = "Darley-sans.otf"
    if bold: name = "Dela-gothic-one.ttf"
    if zen: name = "Zen-dots.ttf"
    if arial: name = "arial.ttf"
    return FontLib.Load(name, int(size))

def WrapText(d, text, f, w):
    words = (text or "").split()
    if not words:
        return [""]
    out, cur = [], words[0]
    for x in words[1:]:
        t = f"{cur} {x}"
        if d.textlength(t, font=f) <= w:
            cur = t
        else:
            out.append(cur)
            cur = x
    out.append(cur)
    return out

def FitText(d, text, f, w):
    s = str(text or "")
    if d.textlength(s, font=f) <= w:
        return s
    ell = "..."
    w2 = w - d.textlength(ell, font=f)
    out = ""
    for ch in s:
        if d.textlength(out + ch, font=f) > w2:
            break
        out += ch
    return out + ell

def RoundedMask(w, h, r, aa=5):
    mw, mh = w * aa, h * aa
    mr = int(min(r, w // 2, h // 2) * aa)
    m = Image.new("L", (mw, mh), 0)
    ImageDraw.Draw(m).rounded_rectangle((0, 0, mw, mh), mr, fill=255)
    return m.resize((w, h), Image.LANCZOS)

def Glass(canvas, box, r, alpha=(255, 255, 255, 10), blur=18, aa=4):
    x1, y1, x2, y2 = box
    w, h = x2 - x1, y2 - y1
    bg = canvas.crop(box).filter(ImageFilter.GaussianBlur(blur))
    layer = Image.alpha_composite(bg, Image.new("RGBA", (w, h), alpha))
    canvas.paste(layer, box, RoundedMask(w, h, r, aa=aa))

def Shadow(canvas, box, r, ox, oy, blur):
    x1, y1, x2, y2 = box
    layer = Image.new("RGBA", canvas.size, (0, 0, 0, 0))
    m = Image.new("L", canvas.size, 0)
    ImageDraw.Draw(m).rounded_rectangle((x1 + ox, y1 + oy, x2 + ox, y2 + oy), r, fill=220)
    layer.putalpha(m.filter(ImageFilter.GaussianBlur(blur)))
    return Image.alpha_composite(canvas, layer)

def HasRealAlpha(im):
    if im is None or im.mode != "RGBA":
        return False
    mn, mx = im.getchannel("A").getextrema()
    return mn < 255

def RemoveBgRembg(im):
    if im is None:
        return None
    im = im.convert("RGBA") if im.mode != "RGBA" else im
    if RembgRemove is None or HasRealAlpha(im):
        return im
    try:
        out = RembgRemove(im)
        if not isinstance(out, Image.Image):
            from io import BytesIO
            out = Image.open(BytesIO(out))
        out = out.convert("RGBA")
        bb = out.getbbox()
        if not bb:
            return im
        outc = out.crop(bb)
        a = outc.getchannel("A")
        mn, mx = a.getextrema()
        if mx < 32:
            return im
        if outc.size[0] * outc.size[1] < 256:
            return im
        return outc
    except Exception:
        return im

def FindDistroLogo(distro, target):
    s = (distro or "").strip()
    if not s:
        return None

    if os.path.exists(s):
        try:
            im = Image.open(s).convert("RGBA")
            w, h = im.size
            if w > 0 and h > 0:
                k = float(target) / float(max(w, h))
                return im.resize((max(1, int(w * k)), max(1, int(h * k))), Image.LANCZOS)
        except Exception:
            return None

    key = s.lower().replace(" ", "").replace("_", "").replace("-", "")
    alias = {
        "arch": ["arch", "archlinux"],
        "archlinux": ["archlinux", "arch"],
        "ubuntu": ["ubuntu"],
        "debian": ["debian"],
        "fedora": ["fedora"],
        "manjaro": ["manjaro"],
        "endeavouros": ["endeavouros", "endeavor"],
        "pop": ["popos", "pop"],
        "popos": ["popos", "pop"],
        "kali": ["kali"],
        "mint": ["linuxmint", "mint"],
        "linuxmint": ["linuxmint", "mint"],
    }.get(key, [key])

    dirs = [
        os.path.expanduser("~/.config/fastfetch/logos"),
        os.path.expanduser("~/.config/neofetch"),
        os.path.expanduser("~/.local/share/icons"),
        "/usr/share/pixmaps",
        "/usr/share/icons/hicolor/256x256/apps",
        "/usr/share/icons/hicolor/128x128/apps",
        "/usr/share/icons/hicolor/64x64/apps",
    ]
    exts = {".png", ".webp", ".jpg", ".jpeg"}

    def normStem(fn):
        t = os.path.splitext(os.path.basename(fn))[0].lower()
        return t.replace(" ", "").replace("_", "").replace("-", "")

    for d in dirs:
        if not os.path.isdir(d):
            continue
        try:
            for fn in os.listdir(d):
                p = os.path.join(d, fn)
                if not os.path.isfile(p):
                    continue
                if os.path.splitext(fn)[1].lower() not in exts:
                    continue
                st = normStem(fn)
                if not any(a in st for a in alias):
                    continue
                try:
                    im = Image.open(p).convert("RGBA")
                    w, h = im.size
                    if w <= 0 or h <= 0:
                        continue
                    k = float(target) / float(max(w, h))
                    return im.resize((max(1, int(w * k)), max(1, int(h * k))), Image.LANCZOS)
                except Exception:
                    pass
        except Exception:
            pass

    return None

def RenderSysTerminal(data, distro, outDir=None, width=1100):
    outDir = outDir or os.path.join(os.path.expanduser("~"), ".cache", "bot")
    os.makedirs(outDir, exist_ok=True)

    scale = 2
    W = int(width * scale)

    bg = (8, 8, 10, 255)
    fg = (245, 245, 245, 255)
    sub = (190, 190, 190, 255)
    linec = (70, 70, 70, 255)

    pad = int(28 * scale)
    gap = int(22 * scale)
    cardpad = int(30 * scale)
    r = int(22 * scale)

    ftitle = Font(28 * scale, bold=True)   
    flabel = Font(20 * scale)             
    fdistro = Font(26 * scale, bold=True) 

    tmp = Image.new("RGBA", (W, 10), bg)
    d0 = ImageDraw.Draw(tmp)

    sys = data.get("sys") or {}
    net = data.get("net") or {}

    titleH = ftitle.getbbox("Ag")[3] - ftitle.getbbox("Ag")[1]
    rowH = (flabel.getbbox("Ag")[3] - flabel.getbbox("Ag")[1]) + int(12 * scale)

    cardW = W - pad * 2
    kW = int(250 * scale)
    vW = (cardW - cardpad * 2) - kW
    logoBoxH = int(190 * scale)           
    logoTarget = int(140 * scale)         
    logoYPadTop = int(10 * scale)         
    distroTextGap = int(10 * scale)       

    logo = RemoveBgRembg(FindDistroLogo(distro, logoTarget))
    if logo is not None:
        bb = logo.getbbox()
        if bb:
            logo = logo.crop(bb)

    distroName = (str(distro) or "unknown").upper()

    infoRows = [
        ("OS", str(sys.get("os") or "")),
        ("Uptime", str(sys.get("uptime") or "")),
        ("Kernel", str(sys.get("kernel") or "")),
        ("Arch", str(sys.get("arch") or "")),
        ("Session", f'{sys.get("session") or ""} wl={sys.get("wayland") or ""} x11={sys.get("x11") or ""}'),
        ("DE", str(sys.get("de") or "")),
        ("Shell", str(sys.get("shell") or "")),
        ("GPU", str(sys.get("vga") or sys.get("nvidia") or "")),
    ]
    perfRows = [
        ("CPU", str(sys.get("cpu") or "")),
        ("CPU Usage", f'{sys.get("cpuCores") or ""} cores  util {sys.get("cpuPct") if sys.get("cpuPct") is not None else ""}%'),
        ("RAM Usage", f'{sys.get("ramUsed") or ""} / {sys.get("ramTotal") or ""}  free {sys.get("ramFree") or ""}'),
        ("Disk Usage", f'{sys.get("diskUsed") or ""} / {sys.get("diskTotal") or ""}  free {sys.get("diskFree") or ""}'),
        ("Temp", f'cpu {sys.get("tempCpu") or ""}  gpu {sys.get("tempGpu") or ""}'),
    ]
    netRows = [
        ("IF", str(net.get("iface") or "")),
        ("IPv4", str(net.get("ipv4") or "")),
        ("DNS", str(net.get("dns") or "")),
        ("WiFi", f'{net.get("ssid") or ""} sig {net.get("signal") or ""}%'),
        ("Ping", str(net.get("ping") or "")),
        ("Traffic", f'{net.get("sent") or ""} up  {net.get("recv") or ""} down'),
    ]

    def measureRows(rows):
        h = 0
        for k, v in rows:
            lines = WrapText(d0, v, flabel, vW)
            h += max(rowH, len(lines) * rowH)
        return h

    headerH = titleH + int(18 * scale) + 2 + int(18 * scale)

    infoH = cardpad * 2 + logoBoxH + headerH + measureRows(infoRows)
    perfH = cardpad * 2 + headerH + measureRows(perfRows)
    netH  = cardpad * 2 + headerH + measureRows(netRows)

    H = pad * 2 + infoH + gap + perfH + gap + netH
    img = Image.new("RGBA", (W, int(H)), bg)

    def CardBox(yTop, hh):
        return (pad, yTop, pad + cardW, yTop + hh)

    yTop = pad
    b1 = CardBox(yTop, infoH); yTop += infoH + gap
    b2 = CardBox(yTop, perfH); yTop += perfH + gap
    b3 = CardBox(yTop, netH)

    for b in (b1, b2, b3):
        img = Shadow(img, b, r, int(14 * scale), int(14 * scale), int(18 * scale))
        Glass(img, b, r, alpha=(255, 255, 255, 10), blur=18, aa=4)

    d = ImageDraw.Draw(img)

    def Txt(x, y, t, f, c, sw=2):
        d.text((x, y), t, font=f, fill=c, stroke_width=sw, stroke_fill=(0, 0, 0, 220))

    def Sep(x, y, right):
        d.line((x, y, right, y), fill=linec, width=max(1, int(2 * scale)))

    def drawHeader(x, y, right, title):
        Txt(x, y, title, ftitle, fg, 4)
        y += titleH + int(18 * scale)
        Sep(x, y, right)
        return y + int(18 * scale)

    def drawKV(x, y, right, k, v):
        Txt(x, y, f"{k}:", flabel, sub, 2)
        vx = x + kW
        lines = WrapText(d0, v, flabel, right - vx)
        for i, line in enumerate(lines[:3]):
            Txt(vx, y + i * rowH, line, flabel, fg, 2)
        return y + max(rowH, len(lines[:3]) * rowH)

    def drawLogoCenter(x, y, right):
        
        boxW = right - x
        y0 = y + logoYPadTop

        if logo is not None:
            lw, lh = logo.size
            lx = x + (boxW - lw) // 2   
            img.paste(logo, (int(lx), int(y0)), logo)  
            y0 += lh + distroTextGap
        else:
            y0 += int(40 * scale)

        tw = d0.textlength(distroName, font=fdistro)
        tx = x + (boxW - int(tw)) // 2
        Txt(tx, y0, distroName, fdistro, fg, 4)
        y0 += (fdistro.getbbox("Ag")[3] - fdistro.getbbox("Ag")[1]) + int(10 * scale)
        return y + logoBoxH

    def DrawInfo(box):
        x1, y1, x2, y2 = box
        x = x1 + cardpad
        right = x2 - cardpad
        y = y1 + cardpad

        y = drawLogoCenter(x, y, right)
        y = drawHeader(x, y, right, "Information")
        for k, v in infoRows:
            y = drawKV(x, y, right, k, v)

    def DrawPerf(box):
        x1, y1, x2, y2 = box
        x = x1 + cardpad
        right = x2 - cardpad
        y = y1 + cardpad

        y = drawHeader(x, y, right, "Performance")
        for k, v in perfRows:
            y = drawKV(x, y, right, k, v)

    def DrawNet(box):
        x1, y1, x2, y2 = box
        x = x1 + cardpad
        right = x2 - cardpad
        y = y1 + cardpad

        y = drawHeader(x, y, right, "Network")
        for k, v in netRows:
            y = drawKV(x, y, right, k, v)

    DrawInfo(b1)
    DrawPerf(b2)
    DrawNet(b3)

    out = img.resize((width, int(H / scale)), Image.LANCZOS).convert("RGB")
    path = os.path.join(outDir, f"sys_{int(time.time())}.png")
    out.save(path, "PNG", optimize=True)
    return path, out.size[0], out.size[1]