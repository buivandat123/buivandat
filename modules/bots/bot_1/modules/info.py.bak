import json
from zlapi.models import Message, MultiMsgStyle, MessageStyle, ThreadType

def _sty(text, color):
    h = len(text.split("\n")[0]) + 1
    return MultiMsgStyle([
        MessageStyle(offset=0, length=len(text), style="font", size="9", auto_format=False),
        MessageStyle(offset=0, length=h, style="color", color=color, auto_format=False),
        MessageStyle(offset=0, length=h, style="bold", auto_format=False),
    ])

def _sty_mention(text, tag_len, color):
    header_start = tag_len + 1
    header_end = text.find("\n", header_start)
    if header_end == -1:
        header_end = len(text)
    header_len = header_end - header_start + 1
    return MultiMsgStyle([
        MessageStyle(offset=0, length=len(text), style="font", size="9", auto_format=False),
        MessageStyle(offset=header_start, length=header_len, style="color", color=color, auto_format=False),
        MessageStyle(offset=header_start, length=header_len, style="bold", auto_format=False),
    ])

def sty_ok(t): return _sty(t, "#15A85F")
def sty_warn(t): return _sty(t, "#F7B503")
def sty_err(t): return _sty(t, "#DB342E")
def sty_info(t): return _sty(t, "#00BFFF")

def _name(client, uid):
    try:
        p = client.fetchUserInfo(uid).changed_profiles.get(str(uid), {})
        return p.get("displayName", str(uid))
    except:
        return str(uid)

def _mention_msg(client, uid, header, lines, color):
    name = _name(client, uid)
    tag = f"@{name}"
    body = "\n".join(f"    {l}" for l in lines)
    text = f"{tag}\n{header}\n{body}"
    info = json.dumps([{"pos": 0, "uid": str(uid), "len": len(tag)}])
    style = _sty_mention(text, len(tag), color)
    return Message(text=text, mention=info, style=style)

def _reply(client, msg_obj, tid, ttype, text, sty_fn):
    client.replyMessage(Message(text=text, style=sty_fn(text)), msg_obj, tid, ttype)

def _mention_send(client, uid, tid, ttype, header, lines, color):
    msg = _mention_msg(client, uid, header, lines, color)
    client.sendMentionMessage(msg, tid)

from asset.config import PREFIX
from datetime import datetime

des = {"version": "1.0.0", "credits": "Light", "description": "Xem thông tin người dùng", "power": "Member"}

def _ts(ts):
    try:
        return datetime.fromtimestamp(int(ts)/1000).strftime("%d/%m/%Y %H:%M:%S")
    except:
        return "Không rõ"

def handle_info(message, message_object, thread_id, thread_type, author_id, client):
    uid = None
    if message_object.mentions:
        uid = message_object.mentions[0]["uid"]
    elif getattr(message_object, "quote", None):
        uid = str(message_object.quote.ownerId)
    else:
        parts = message.split()
        if len(parts) > 1 and parts[1].isdigit():
            uid = parts[1]
    if not uid:
        uid = author_id

    try:
        p = client.fetchUserInfo(uid).changed_profiles.get(str(uid), {})
        if not p:
            _reply(client, message_object, thread_id, thread_type, "WARNING\n    Không tìm thấy user!", sty_warn)
            return

        g = p.get("gender")
        status = p.get("status", "Không rõ")
        is_blocked = "Có" if p.get("isBlocked") == 1 else "Không"
        is_active_web = "Có" if p.get("isActiveWeb") == 1 else "Không"
        last_active = _ts(p.get("lastActionTime", 0))
        created = _ts(p.get("createdTs", 0))
        avatar = p.get("avatar", "Không có")
        cover = p.get("cover", "Không có")

        biz = p.get("bizPkg", {})
        if isinstance(biz, dict):
            label = biz.get("label", {})
            biz_name = label.get("VI", label.get("EN", "Không")) if isinstance(label, dict) else "Không"
        else:
            biz_name = "Không"

        lines = [
            f"Tên: {p.get('displayName', 'Không rõ')}",
            f"UID: {p.get('userId', uid)}",
            f"Username: {p.get('username', 'Không rõ')}",
            f"Giới tính: {'Nam' if g == 0 else 'Nữ' if g == 1 else 'Ẩn'}",
            f"Ngày sinh: {p.get('sdob', 'Không rõ')}",
            f"Trạng thái: {status}",
            f"Bạn bè: {'Có' if p.get('isFr') == 1 else 'Không'}",
            f"Bị chặn: {is_blocked}",
            f"Online PC: {'Có' if p.get('isActivePC') == 1 else 'Không'}",
            f"Online Web: {is_active_web}",
            f"Hoạt động lần cuối: {last_active}",
            f"Ngày tạo: {created}",
            f"Business: {biz_name}",
            f"Avatar: {avatar}",
            f"Ảnh bìa: {cover}",
        ]
        _mention_send(client, uid, thread_id, thread_type, "THONG TIN NGUOI DUNG", lines, "#00BFFF")

    except Exception as e:
        _reply(client, message_object, thread_id, thread_type, f"ERROR\n    {str(e)[:60]}", sty_err)

def LIGHT():
    return {"info": handle_info}